generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites  Favorite[]
  histories  History[]
  danmakus   Danmaku[]
  donationImages DonationImage[]
}

model Favorite {
  id        String   @id @default(cuid())
  animeId   String
  animeName String
  animeCover String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animeId, userId])
}

model History {
  id          String   @id @default(cuid())
  animeId     String
  animeName   String
  animeCover  String?
  episodeId   String?
  episodeName String?
  progress    Float    @default(0)
  userId      String
  watchedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animeId, episodeId, userId])
}

model Danmaku {
  id        String   @id @default(cuid())
  animeId   String
  episodeId String
  text      String
  color     String   @default("#ffffff")
  type      Int      @default(0)
  time      Float
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model VideoSource {
  id        String   @id @default(cuid())
  name      String
  apiUrl    String
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id        String   @id @default(cuid())
  animeId   String
  animeName String
  animePic  String?
  dayOfWeek Int      // 0=周日 1=周一 ... 6=周六
  timeSlot  String?  // 如 "22:00"
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonationImage {
  id        String   @id @default(cuid())
  userId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
