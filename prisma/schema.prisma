generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites  Favorite[]
  histories  History[]
  donationImages DonationImage[]
  comments   Comment[]
  notifications Notification[]
}

model Favorite {
  id        String   @id @default(cuid())
  animeId   String
  animeName String
  animeCover String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animeId, userId])
}

model History {
  id          String   @id @default(cuid())
  animeId     String
  animeName   String
  animeCover  String?
  episodeId   String?
  episodeName String?
  progress    Float    @default(0)
  userId      String
  watchedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([animeId, episodeId, userId])
}

model VideoSource {
  id        String   @id @default(cuid())
  name      String   // 源标识，如 bfzyapi
  apiUrl    String
  typeId    Int      @default(41) // CMS 类型ID（日本动漫），bfzy=41, ffzy=30
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id        String   @id @default(cuid())
  animeId   String
  animeName String
  animePic  String?
  dayOfWeek Int      // 0=周日 1=周一 ... 6=周六
  timeSlot  String?  // 如 "22:00"
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonationImage {
  id        String   @id @default(cuid())
  userId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Carousel {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  badge     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnimeCatalog {
  id          String   @id
  name        String
  cover       String?
  year        Int?
  area        String?
  type        String?
  className   String?   // vod_class
  remarks     String?
  score       String?
  description String?   // vod_content (stripped HTML)
  vodTime     String?   // e.g. "2025-07-14" — used for quarter calculation
  sourceId    String   // which API source
  sourceUrl   String?   // original API URL
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([year])
  @@index([type])
  @@index([name])
  @@index([updatedAt])
}

model Comment {
  id        String   @id @default(cuid())
  animeId   String
  episodeId String?
  text      String
  rating    Int?     // 1-5 star rating
  parentId  String?  // for replies
  userId    String?
  createdAt DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null = 全站公告, 有值 = 私发给特定用户
  title     String
  message   String
  type      String   @default("system") // system, bug_reply, announcement
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
